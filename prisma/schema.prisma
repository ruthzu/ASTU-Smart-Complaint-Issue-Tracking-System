// This is the Prisma schema file for PostgreSQL
// Defines a User model with id, name, email, and role

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  STAFF
  ADMIN
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
  role  Role
  password String
  complaints Complaint[]
  assignedComplaints Complaint[] @relation("AssignedStaff")
}

model Department {
  id Int @id @default(autoincrement())
  name String
  complaints Complaint[]
}

model Complaint {
  id Int @id @default(autoincrement())
  title String
  description String
  status ComplaintStatus
  remarks String?
  category String
  attachment String?
  userId Int
  user User @relation(fields: [userId], references: [id])
  assignedStaffId Int?
  assignedStaff User? @relation("AssignedStaff", fields: [assignedStaffId], references: [id])
  departmentId Int?
  department Department? @relation(fields: [departmentId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
